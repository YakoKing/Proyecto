<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#00FF9C"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgPistaReserva"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:scaleType="centerCrop"
            android:src="@drawable/pista_ejemplo"
            app:shapeAppearanceOverlay="@style/circuloAvatar" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/txtNombrePistaReserva"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre pista #1"
                android:textColor="#00FF9C"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtFechaReserva"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Fecha: 2024-05-15"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtHorarioReserva"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="18:00 - 19:00"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnCancelarReserva"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:textColor="#FF5252"
            android:textSize="13sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
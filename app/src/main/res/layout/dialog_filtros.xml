<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#121212"
    app:cardCornerRadius="0dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <!-- Título Personalizado -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0D0D0D"
            android:padding="16dp"
            android:text="FILTRAR Y ORDENAR"
            android:textColor="#00FF9C"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filtrar por provincia"
                    android:textColor="#00FF9C"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#333333">

                    <Spinner
                        android:id="@+id/spinnerProvincia"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#00FF9C"
                        android:paddingStart="8dp"
                        android:popupBackground="#1E1E1E" />

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#333333"
                    android:layout_marginVertical="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ordenar por precio"
                    android:textColor="#00FF9C"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <RadioGroup
                    android:id="@+id/rgOrden"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <RadioButton
                        android:id="@+id/rbSinOrden"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin orden específico"
                        android:textColor="#FFFFFF"
                        android:padding="8dp"
                        android:buttonTint="#00FF9C" />

                    <RadioButton
                        android:id="@+id/rbPrecioAsc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Precio: Menor a mayor"
                        android:textColor="#FFFFFF"
                        android:padding="8dp"
                        android:buttonTint="#00FF9C" />

                    <RadioButton
                        android:id="@+id/rbPrecioDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Precio: Mayor a menor"
                        android:textColor="#FFFFFF"
                        android:padding="8dp"
                        android:buttonTint="#00FF9C" />
                </RadioGroup>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Botones Personalizados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0D0D0D"
            android:orientation="horizontal"
            android:gravity="end"
            android:padding="8dp">

            <Button
                android:id="@+id/btnLimpiar"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Limpiar"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnCancelar"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnAplicar"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aplicar"
                android:textColor="#00FF9C" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1A1A1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Provincia"
        android:textColor="#00FF9C"
        android:textStyle="bold"
        android:textSize="14sp" />

    <Spinner
        android:id="@+id/spinnerProvincia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#00FF9C" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ordenar por precio"
        android:textColor="#00FF9C"
        android:textStyle="bold"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/rgOrden"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <RadioButton
            android:id="@+id/rbSinOrden"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sin orden específico"
            android:textColor="#FFFFFF"
            android:buttonTint="#00FF9C" />

        <RadioButton
            android:id="@+id/rbPrecioAsc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precio: Menor a mayor"
            android:textColor="#FFFFFF"
            android:buttonTint="#00FF9C" />

        <RadioButton
            android:id="@+id/rbPrecioDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precio: Mayor a menor"
            android:textColor="#FFFFFF"
            android:buttonTint="#00FF9C" />
    </RadioGroup>

</LinearLayout>